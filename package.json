{
  "name": "ledger-suite",
  "private": true,
  "type": "module",
  "workspaces": ["packages/ledger", "packages/ledger-live", "packages/ledger-mcp", "packages/ledger-tui", "packages/ledger-web"],
  "scripts": {
    "check": "tsc -b && eslint . && bun test",
