{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "types": ["bun-types", "react", "react-dom"],
    "paths": {
      "@cq/config": ["../cq-config/src/index.ts"],
      "@cq/ledger": ["../ledger/src/index.ts"],
      "@cq/ledger/relationships": ["../ledger/src/relationships.ts"],
      "@cq/ledger/columns": ["../ledger/src/columns.ts"],
      "@cq/ledger/constants": ["../ledger/src/constants.ts"],
      "@cq/ledger-live": ["../ledger-live/src/index.ts"],
      "@cq/ledger-mcp": ["../ledger-mcp/src/main.ts"]
    }
  },
  "references": [
    { "path": "../cq-config" },
    { "path": "../ledger" },
    { "path": "../ledger-live" },
    { "path": "../ledger-mcp" }
  ],
  "include": ["src", "test"]
}
