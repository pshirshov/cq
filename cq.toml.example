# cq.toml — optional configuration for the cq review orchestrator
#
# This file documents the schema for configuring reviewers and planners in the
# cq review flows. Absence of cq.toml means only the native Claude reviewer
# (feature off).
#
# Schema:
#   [aliases]        — table mapping alias names to reviewer tokens
#   reviewers = [...] — top-level array of alias names to activate as reviewers
#   planners  = [...] — top-level array of alias names to activate as planners
#   [tiers]          — CLASSIFIER: maps each <harness>:<model> token (or alias) -> tier class
#   [agent_tiers]    — maps agent-name -> tier name (default: "standard")

# reviewers — List of ALIAS NAMES (keys from [aliases] below) to activate as reviewers.
# Each alias is resolved through [aliases] to its reviewer token at runtime.
# The reviewers will be invoked in plan-flow and implement-flow review steps.
reviewers = ["codex", "grok", "opus"]

# planners — List of ALIAS NAMES to activate as planners. Planners MIRROR
# reviewers: same alias-name list shape, resolved through the SAME shared
# [aliases] table below.
planners = ["opus", "grok"]

# [aliases] — Define reviewer instances as reviewer tokens.
#
# Token grammar (BREAKING in this version):
#   - pi tokens MUST be: pi:<provider>/<model>
#     The provider is the pi `--provider` flag value; model is the pi `--model`.
#     E.g.: pi:ollama-cloud/minimax-m3, pi:grok-build/grok-build
#     A bare pi token WITHOUT a provider qualifier (e.g. pi:minimax) is a
#     CONFIG ERROR and will be rejected at parse time.
#     MIGRATION: if you were using pi:minimax, update to pi:ollama-cloud/minimax-m3
#   - claude tokens MUST be: claude:<model>
#     The model is the Claude model identifier (e.g. opus-4.8[1m], haiku-4.5).
#     Provider qualifiers (/) are NOT permitted on claude tokens and will
#     be rejected as a CONFIG ERROR.
#
# [tiers] KEY grammar (same as above): keys must be valid ReviewerTokens — either
# an alias name from this [aliases] table, or a full token in the grammar above
# (claude:<model> | pi:<provider>/<model>).  A bare pi key or unknown harness in
# a [tiers] key is rejected as a CONFIG ERROR at parse time.
#
# Reference: D36 (pi provider routing)
[aliases]
  codex = "pi:grok-build/grok-build"
  grok = "pi:grok-build/grok-build"
  opus = "claude:opus-4.8[1m]"
  minimax = "pi:ollama-cloud/minimax-m3"

# [tiers] — CLASSIFIER: maps each concrete (harness, provider, model) token to
# its dispatch tier class.  THIS IS NOT A DISPATCH TABLE — it tells cq what
# tier a given token belongs to; the active planner/reviewer candidate list is
# built from [aliases]+reviewers/planners, and a suggestedModel tier selects
# among those listed tokens whose class matches (tie-break: candidate order).
#
# Each KEY must be a valid ReviewerToken (alias name from [aliases], or a
# full token in the grammar below: claude:<model> | pi:<provider>/<model>).
# Each VALUE is the tier class assigned to that token.  A token not listed
# here is unclassified; resolving an unclassified token throws CqConfigError.
#
# Both key forms are demonstrated below: "minimax" is an alias key (resolved
# through [aliases] to pi:ollama-cloud/minimax-m3 at parse time), while the
# remaining entries use full token keys.  Either form is accepted; use aliases
# to avoid repeating the full token string when one is already declared above.
#
# Tier classes:
#   fast     — cheapest/fastest (e.g. a small Pi provider)
#   standard — balanced (default tier for agents with no [agent_tiers] entry)
#   frontier — most capable (e.g. Claude Opus or Grok)
[tiers]
  "claude:opus-4.8[1m]"           = "frontier"    # full token key
  minimax                          = "fast"         # alias key (resolves to pi:ollama-cloud/minimax-m3)
  "pi:grok-build/grok-build"      = "standard"    # full token key

# [agent_tiers] — Map each named cq agent to its dispatch tier.
# An agent with NO entry here falls back to the "standard" tier.
# The tier name here selects, from the active reviewers/planners candidate list,
# the first token whose class (as classified in [tiers] above) matches the tier.
# Valid tier values: "fast", "standard", "frontier".
[agent_tiers]
  investigate-explorer    = "frontier"
  investigate-prober      = "standard"
  plan-advance            = "standard"
  plan-reviewer           = "frontier"
  implement-worker        = "standard"
  implement-reviewer      = "standard"
  implement-conflict-resolver = "standard"
