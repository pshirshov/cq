# cq.toml — optional configuration for the cq review orchestrator
#
# This file documents the schema for configuring reviewers and planners in the
# cq review flows. Absence of cq.toml means only the native Claude reviewer
# (feature off).
#
# Schema:
#   [aliases]        — table mapping alias names to reviewer tokens
#   reviewers = [...] — top-level array of alias names to activate as reviewers
#   planners  = [...] — top-level array of alias names to activate as planners
#   [tiers]          — maps fast/standard/frontier -> <harness>:<model> token or alias
#   [agent_tiers]    — maps agent-name -> tier name (default: "standard")

# reviewers — List of ALIAS NAMES (keys from [aliases] below) to activate as reviewers.
# Each alias is resolved through [aliases] to its reviewer token at runtime.
# The reviewers will be invoked in plan-flow and implement-flow review steps.
reviewers = ["codex", "grok", "opus"]

# planners — List of ALIAS NAMES to activate as planners. Planners MIRROR
# reviewers: same alias-name list shape, resolved through the SAME shared
# [aliases] table below.
planners = ["opus", "grok"]

# [aliases] — Define reviewer instances as <harness>:<model> tokens.
# Harnesses: "claude" (Claude API), "pi" (Pi/Pika API)
# Models: e.g., opus-4.8[1m], haiku-4.5, sonnet-4, grok-build, etc.
[aliases]
  codex = "pi:grok-build"
  grok = "pi:grok-build"
  opus = "claude:opus-4.8[1m]"
  minimax = "pi:minimax-m3"

# [tiers] — Map the three dispatch tiers to a concrete provider+model.
# Values are either an alias name (from [aliases] above) or a direct token.
# Absent tier slots are not configured; resolving them throws CqConfigError.
# Default suggestion:
#   fast     — cheapest/fastest (e.g. a small Pi provider)
#   standard — balanced (default tier for agents with no [agent_tiers] entry)
#   frontier — most capable (e.g. Claude Opus or Grok)
[tiers]
  fast     = "minimax"
  standard = "grok"
  frontier = "opus"

# [agent_tiers] — Map each named cq agent to its dispatch tier.
# An agent with NO entry here falls back to the "standard" tier.
# Valid tier values: "fast", "standard", "frontier".
[agent_tiers]
  investigate-explorer    = "frontier"
  investigate-prober      = "standard"
  plan-advance            = "standard"
  plan-reviewer           = "frontier"
  implement-worker        = "standard"
  implement-reviewer      = "standard"
  implement-conflict-resolver = "standard"
