{
  "name": "cq",
  "private": true,
  "type": "module",
  "workspaces": ["packages/shared", "packages/ledger", "packages/cq-mcp", "packages/ledger-mcp", "packages/server", "packages/web", "packages/e2e"],
  "scripts": {
    "check": "tsc -b && eslint . && bun test",
    "typecheck": "tsc -b",
    "lint": "eslint packages",
    "format": "prettier --write .",
    "test": "bun test --pass-with-no-tests",
    "start": "bun run packages/server/src/main.ts --cwd /tmp --port 5173",
    "dev": "bun run packages/server/src/main.ts -- --dev --cwd . --port 5173",
    "e2e": "cd packages/e2e && bun x playwright test",
    "e2e:headed": "cd packages/e2e && bun x playwright test --headed"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.34.0"
  }
}
